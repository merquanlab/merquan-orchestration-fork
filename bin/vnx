  python3 "$tracker_script" "$@"
}

cmd_smoke() {
  local tmp_dir="/tmp"
  local keep=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --tmp-dir)
        shift
        if [ "$#" -eq 0 ]; then
          err "[smoke] --tmp-dir requires a directory path"
          return 1
        fi
        tmp_dir="$1"
        ;;
      --keep)
        keep=1
        ;;
      -h|--help)
        cat <<SMOKE_USAGE
Usage: vnx smoke [--tmp-dir <dir>] [--keep]

Options:
  --tmp-dir <dir>  Parent temp directory (default: /tmp)
  --keep           Keep temp workspace for inspection
SMOKE_USAGE
        return 0
        ;;
      *)
        err "[smoke] Unknown option: $1"
        return 1
        ;;
    esac
    shift
  done

  local workspace=""
  if [ "$tmp_dir" = "/tmp" ]; then
    workspace="$(mktemp -d "/tmp/vnx-smoke.XXXXXX")"
  else
    mkdir -p "$tmp_dir"
    workspace="$tmp_dir/vnx-smoke-$(date +%Y%m%d%H%M%S)-$$"
    mkdir -p "$workspace"
  fi

  if [ ! -d "$workspace" ]; then
    err "[smoke] Failed to create temp workspace"
    return 1
  fi

  if [ "$keep" -eq 0 ]; then
    trap "rm -rf '$workspace' 2>/dev/null || true" RETURN
  fi

  local smoke_data_dir="$workspace/.vnx-data"
  local smoke_state_dir="$smoke_data_dir/state"
  local smoke_dispatch_dir="$smoke_data_dir/dispatches"
  local smoke_logs_dir="$smoke_data_dir/logs"
  local smoke_pids_dir="$smoke_data_dir/pids"
  local smoke_locks_dir="$smoke_data_dir/locks"
  local smoke_reports_dir="$smoke_data_dir/unified_reports"
  local smoke_db_dir="$smoke_data_dir/database"
  local smoke_receipts_file="$smoke_state_dir/t0_receipts.ndjson"
  local processor_script="$VNX_HOME/scripts/receipt_processor_v4.sh"

  mkdir -p "$smoke_state_dir" \
    "$smoke_logs_dir" \
    "$smoke_pids_dir" \
    "$smoke_locks_dir" \
    "$smoke_dispatch_dir/pending" \
    "$smoke_dispatch_dir/active" \
    "$smoke_dispatch_dir/completed" \
    "$smoke_dispatch_dir/rejected" \
    "$smoke_dispatch_dir/failed" \
    "$smoke_reports_dir" \
    "$smoke_db_dir"

  touch "$smoke_receipts_file"

  local before_count
  before_count="$(wc -l < "$smoke_receipts_file" 2>/dev/null || echo 0)"

  local now_date now_ts dispatch_id report_path
  now_date="$(date -u +%Y-%m-%d)"
  now_ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  dispatch_id="smoke-dispatch-$(date -u +%Y%m%d%H%M%S)-$$"
  report_path="$smoke_reports_dir/$(date -u +%Y%m%d-%H%M%S)-${dispatch_id}-T1.md"

  cat > "$report_path" <<EOF
# IMPLEMENTATION: Smoke Receipt Test

## Metadata
- **Terminal**: T1
- **Date**: $now_date
- **Gate**: testing
- **Status**: success
- **Task ID**: smoke-task-001
- **Dispatch ID**: $dispatch_id
- **Track**: A
- **Timestamp**: $now_ts

## Summary
One-shot smoke test report to validate receipt generation.

## Tags (Required)
- [smoke-test, receipt-pipeline]

## Work Completed
- Created deterministic smoke report.
- Executed one-shot receipt processing.

## Technical Details
- Uses receipt_processor_v4 in manual mode.

## Evidence
- Receipt line should be appended to t0_receipts.ndjson.

## Open Items
None - all work completed and tested.

## Recommendations
### Immediate
- Keep smoke test in CI.
EOF

  if [ ! -f "$processor_script" ]; then
    err "[smoke] Missing processor script: $processor_script"
    return 1
  fi

  if ! VNX_DATA_DIR="$smoke_data_dir" \
    VNX_STATE_DIR="$smoke_state_dir" \
    VNX_DISPATCH_DIR="$smoke_dispatch_dir" \
    VNX_LOGS_DIR="$smoke_logs_dir" \
    VNX_PIDS_DIR="$smoke_pids_dir" \
    VNX_LOCKS_DIR="$smoke_locks_dir" \
    VNX_REPORTS_DIR="$smoke_reports_dir" \
    VNX_DB_DIR="$smoke_db_dir" \
    VNX_MODE=manual \
    bash "$processor_script"; then
    err "[smoke] Receipt processor failed"
    return 1
  fi

  local after_count
  after_count="$(wc -l < "$smoke_receipts_file" 2>/dev/null || echo 0)"
  if [ "$after_count" -le "$before_count" ]; then
    err "[smoke] FAILED: no new receipt appended to $smoke_receipts_file"
    return 1
  fi

  log "[smoke] PASSED: receipt appended ($before_count -> $after_count)"
  if [ "$keep" -eq 1 ]; then
    log "[smoke] Kept temp workspace: $workspace"
  fi
}

cmd_bootstrap_skills() {
  local project_claude_dir="$PROJECT_ROOT/.claude"
  local project_skills_dir="$project_claude_dir/skills"
  local shipped_skills_dir="$VNX_HOME/skills"

  # If skills dir exists as a real directory, keep it (canonical location).
  # If it's a stale symlink, remove it and copy fresh.
  if [ -L "$project_skills_dir" ]; then
    log "[bootstrap-skills] Removing stale symlink: $project_skills_dir"
    rm -f "$project_skills_dir"
  elif [ -d "$project_skills_dir" ]; then
    log "[bootstrap-skills] Keeping existing skills dir: $project_skills_dir"
    return 0
  fi

  if [ ! -d "$shipped_skills_dir" ]; then
    err "[bootstrap-skills] Missing shipped skills dir: $shipped_skills_dir"
    return 1
  fi

  mkdir -p "$project_claude_dir"

  # Copy skills to .claude/skills/ (canonical location).
  # Claude Code does not follow symlinks for skill discovery,
  # so we copy instead. After init, .claude/skills/ is the single
  # source of truth — edit skills there directly.
  if command -v rsync >/dev/null 2>&1; then
    rsync -a "$shipped_skills_dir/" "$project_skills_dir/"
  else
    mkdir -p "$project_skills_dir"
    cp -R "$shipped_skills_dir/." "$project_skills_dir/"
  fi
  log "[bootstrap-skills] Copied skills to: $project_skills_dir"

  if [ -f "$project_skills_dir/skills.yaml" ]; then
    log "[bootstrap-skills] OK: skills registry present"
  else
    err "[bootstrap-skills] WARN: skills.yaml not found in $project_skills_dir"
  fi

  # ── Multi-provider skill sync ─────────────────────────────────────────
  # Each CLI tool has its own skill discovery path. Sync shipped skills
  # to each provider so T1 (multi-model) always has identical capabilities.

  # Codex CLI: reads project skills from .agents/skills/ (project-scoped).
  # We no longer sync to ~/.codex/skills/ (global) to avoid polluting user's
  # global config. Project-local skills are sufficient for VNX dispatches.
  if command -v codex >/dev/null 2>&1; then
    local codex_skills_dir="$PROJECT_ROOT/.agents/skills"
    mkdir -p "$codex_skills_dir"
    if command -v rsync >/dev/null 2>&1; then
      rsync -a "$shipped_skills_dir/" "$codex_skills_dir/"
    else
      cp -R "$shipped_skills_dir/." "$codex_skills_dir/"
    fi
    log "[bootstrap-skills] Synced skills to Codex: $codex_skills_dir"
  fi

  # Gemini CLI: reads skills from <project>/.gemini/skills/ (workspace).
  # Uses same SKILL.md format, just different discovery directory.
  if command -v gemini >/dev/null 2>&1; then
    local gemini_skills_dir="$PROJECT_ROOT/.gemini/skills"
    mkdir -p "$gemini_skills_dir"
    if command -v rsync >/dev/null 2>&1; then
      rsync -a "$shipped_skills_dir/" "$gemini_skills_dir/"
    else
      cp -R "$shipped_skills_dir/." "$gemini_skills_dir/"
    fi
    log "[bootstrap-skills] Synced skills to Gemini: $gemini_skills_dir"
  fi
}

cmd_bootstrap_terminals() {
  local terminals_dir="$PROJECT_ROOT/.claude/terminals"
  local force=0
  local terminal_ids="T0 T1 T2 T3"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --force)
        force=1
        ;;
      --terminals)
        shift
        if [ "$#" -eq 0 ]; then
          err "[bootstrap-terminals] --terminals requires a value (e.g. \"T0 T1 T2 T3\")"
          return 1
        fi
        terminal_ids="$1"
        ;;
      -h|--help)
        cat <<EOF
Usage: vnx bootstrap-terminals [--terminals "T0 T1 T2 T3"] [--force]

Creates per-terminal folders under ./.claude/terminals/ and writes CLAUDE.md
from templates in: $TERMINALS_TEMPLATE_DIR

Defaults:
  --terminals "T0 T1 T2 T3"

Safety:
  Existing CLAUDE.md files are kept unless --force is set.
EOF
        return 0
        ;;
      *)
        err "[bootstrap-terminals] Unknown option: $1"
        return 1
        ;;
    esac
    shift
  done

  mkdir -p "$terminals_dir"

  local terminal_id
  for terminal_id in $terminal_ids; do
    local target_dir="$terminals_dir/$terminal_id"
    local target_file="$target_dir/CLAUDE.md"
    local template_file="$TERMINALS_TEMPLATE_DIR/${terminal_id}.md"

    mkdir -p "$target_dir"

    if [ ! -f "$template_file" ]; then
      err "[bootstrap-terminals] Missing terminal template: $template_file"
      return 1
    fi

    if [ -f "$target_file" ] && [ "$force" -eq 0 ]; then
      log "[bootstrap-terminals] Keeping existing: $target_file"
      continue
    fi

    cp "$template_file" "$target_file"
    log "[bootstrap-terminals] Wrote: $target_file"
  done

  # ── Generate .mcp.json per terminal ──────────────────────────────────
  # Write an empty .mcp.json for each terminal. If the user has global MCP
  # servers in ~/.claude.json, explicitly disable them so they don't leak
  # into project terminals. This ensures predictable behaviour regardless
  # of the user's global Claude Code configuration.
  local global_claude_json="$HOME/.claude.json"
  if command -v python3 >/dev/null 2>&1 && [ -f "$global_claude_json" ]; then
    python3 - "$terminals_dir" "$terminal_ids" "$force" <<'PYEOF'
import json, os, sys

terminals_dir = sys.argv[1]
terminal_ids  = sys.argv[2].split()
force         = sys.argv[3] == "1"

# Read global MCP server definitions
with open(os.path.expanduser("~/.claude.json")) as fh:
    global_mcps = json.load(fh).get("mcpServers", {})

if not global_mcps:
    print("[bootstrap-terminals] No global MCPs detected — skipping .mcp.json generation")
    sys.exit(0)

# Build a config that disables every global MCP server
disable_all = {}
for name, cfg in global_mcps.items():
    entry = dict(cfg)
    entry["disabled"] = True
    disable_all[name] = entry

mcp_config = {"mcpServers": disable_all}

for tid in terminal_ids:
    target = os.path.join(terminals_dir, tid, ".mcp.json")
    if os.path.exists(target) and not force:
        print(f"[bootstrap-terminals] Keeping existing: {target}")
        continue
    os.makedirs(os.path.dirname(target), exist_ok=True)
    with open(target, "w") as fh:
        json.dump(mcp_config, fh, indent=2)
        fh.write("\n")
    print(f"[bootstrap-terminals] Wrote .mcp.json (all globals disabled): {target}")
PYEOF
  else
    # Fallback: write minimal empty config
    for terminal_id in $terminal_ids; do
      local mcp_file="$terminals_dir/$terminal_id/.mcp.json"
      if [ ! -f "$mcp_file" ] || [ "$force" -eq 1 ]; then
        printf '{"mcpServers": {}}\n' > "$mcp_file"
        log "[bootstrap-terminals] Wrote .mcp.json (empty): $mcp_file"
      fi
    done
  fi

  # ── Pre-trust project root for Gemini CLI ────────────────────────────
  # Gemini CLI asks "Do you trust this folder?" on first launch and then
  # crashes during the restart that applies trust (known bug in 0.29.5).
  # Pre-populate ~/.gemini/trustedFolders.json with TRUST_FOLDER for the
  # project root and terminals dir so the dialog never appears.
  local gemini_trust_file="$HOME/.gemini/trustedFolders.json"
  if command -v gemini >/dev/null 2>&1 && command -v python3 >/dev/null 2>&1; then
    python3 - "$PROJECT_ROOT" "$gemini_trust_file" <<'PYEOF'
import json, os, sys

project_root   = sys.argv[1]
trust_file     = sys.argv[2]

new_entries = {
    project_root:                                   "TRUST_FOLDER",
    os.path.join(project_root, ".claude/terminals"): "TRUST_FOLDER",
}

# Load or create
os.makedirs(os.path.dirname(trust_file), exist_ok=True)
if os.path.exists(trust_file):
    with open(trust_file) as fh:
        trust = json.load(fh)
else:
    trust = {}

added = []
for path, level in new_entries.items():
    if path not in trust:
        trust[path] = level
        added.append(path)

with open(trust_file, "w") as fh:
    json.dump(trust, fh, indent=2)
    fh.write("\n")

if added:
    for p in added:
        print(f"[bootstrap-terminals] Gemini trust added: {p}")
else:
    print("[bootstrap-terminals] Gemini trust already set for project root")
PYEOF
  fi

  log "[bootstrap-terminals] Done"
}

cmd_bootstrap_hooks() {
  local project_claude_dir="$PROJECT_ROOT/.claude"
  local project_hooks_dir="$project_claude_dir/hooks"
  local project_settings="$project_claude_dir/settings.json"
  local shipped_hooks_dir="$VNX_HOME/hooks"
  local shipped_hook="$shipped_hooks_dir/sessionstart.sh"

  # ── Step 1: Copy hook scripts ─────────────────────────────────────
  if [ ! -f "$shipped_hook" ]; then
    err "[bootstrap-hooks] Missing shipped hook: $shipped_hook"
    return 1
  fi

  mkdir -p "$project_hooks_dir"

  # Always update hook scripts (they're generic, not user-customized)
  cp "$shipped_hook" "$project_hooks_dir/sessionstart.sh"
  chmod +x "$project_hooks_dir/sessionstart.sh"
  log "[bootstrap-hooks] Deployed: $project_hooks_dir/sessionstart.sh"

  # ── Step 2: Ensure settings.json has hooks + VNX keys ──────────────
  # Delegate to regen-settings for patch-based merge (PR-2).
  # Load the command if not already available.
  if ! type cmd_regen_settings &>/dev/null; then
    _load_command "regen_settings" 2>/dev/null || true
  fi

  if type cmd_regen_settings &>/dev/null; then
    cmd_regen_settings --merge --no-backup
  else
    # Fallback: minimal hooks-only merge (pre-PR-2 compatibility)
    log "[bootstrap-hooks] WARN: regen-settings not available, using legacy merge"
    local hook_script_path="$project_hooks_dir/sessionstart.sh"
    if [ ! -f "$project_settings" ]; then
      log "[bootstrap-hooks] WARN: No settings.json — run 'vnx regen-settings --full' to create"
    elif command -v jq &>/dev/null; then
      if ! jq -e '.hooks' "$project_settings" >/dev/null 2>&1; then
        local tmp_settings="${project_settings}.tmp"
        jq --arg hook_path "bash $hook_script_path" '. + {
          "hooks": {
            "SessionStart": [{
              "matcher": "*",
              "hooks": [{"type": "command", "command": $hook_path, "timeout": 3000}]
            }]
          }
        }' "$project_settings" > "$tmp_settings" && mv "$tmp_settings" "$project_settings"
        log "[bootstrap-hooks] Added hooks section to: $project_settings"
      fi
    fi
  fi

  log "[bootstrap-hooks] Done"
}

# ── vnx worktree-* ─────────────────────────────────────────────────────
# Worktree data isolation: snapshot + write-overlay (Option 1C + 3B)

_detect_worktree_context() {
  # Returns: 0 if in a worktree, 1 if in main repo
  # Sets: _WT_ROOT (worktree toplevel), _MAIN_ROOT (main repo root)
  # PR-3: Delegates to Python module (vnx_worktree.py) when available.
  local _wt_json
  _wt_json="$(PYTHONPATH="$VNX_HOME/scripts/lib:${PYTHONPATH:-}" python3 -c "
import json
from vnx_worktree import detect_worktree_context
ctx = detect_worktree_context('$PROJECT_ROOT')
print(json.dumps({'is_worktree': ctx.is_worktree, 'wt': ctx.worktree_root, 'main': ctx.main_root}))
" 2>/dev/null)" || _wt_json=""

  if [ -n "$_wt_json" ]; then
    local _is_wt
    _is_wt="$(echo "$_wt_json" | python3 -c "import json,sys; print(json.load(sys.stdin)['is_worktree'])" 2>/dev/null)"
    _WT_ROOT="$(echo "$_wt_json" | python3 -c "import json,sys; print(json.load(sys.stdin)['wt'])" 2>/dev/null)"
    _MAIN_ROOT="$(echo "$_wt_json" | python3 -c "import json,sys; print(json.load(sys.stdin)['main'])" 2>/dev/null)"
    [ "$_is_wt" = "True" ] && return 0 || return 1
  fi

  # Fallback: inline git commands (pre-PR-3 behavior)
  local git_common_dir
  git_common_dir="$(git -C "$PROJECT_ROOT" rev-parse --git-common-dir 2>/dev/null)" || return 1
  _MAIN_ROOT="$(cd "$git_common_dir" && cd .. && pwd)"
  _WT_ROOT="$(git -C "$PROJECT_ROOT" rev-parse --show-toplevel 2>/dev/null)" || return 1

  if [ "$_MAIN_ROOT" != "$_WT_ROOT" ]; then
    return 0  # We're in a worktree
  fi
  return 1  # We're in the main repo
}

_snapshot_intelligence() {
  # Copy intelligence data from main to worktree .vnx-data/
  local main_data="$1"
  local wt_data="$2"
  local copied=0

  # Derive subdirectory names from VNX_*_DIR conventions
  local _db_sub; _db_sub="$(basename "$VNX_DB_DIR")"
  local _state_sub; _state_sub="$(basename "$VNX_STATE_DIR")"

  # Snapshot intelligence databases
  for db_name in intelligence.db quality_intelligence.db unified_state.db vnx_intelligence.db; do
    if [ -f "$main_data/$_db_sub/$db_name" ]; then
      cp "$main_data/$_db_sub/$db_name" "$wt_data/$_db_sub/$db_name"
      copied=$((copied + 1))
    fi
  done

  # Snapshot receipt history (learning loop context)
  if [ -f "$main_data/$_state_sub/t0_receipts.ndjson" ]; then
    cp "$main_data/$_state_sub/t0_receipts.ndjson" "$wt_data/$_state_sub/t0_receipts.ndjson"
    copied=$((copied + 1))
  fi

  # Snapshot startup presets
  if [ -d "$main_data/startup_presets" ]; then
    cp -R "$main_data/startup_presets/." "$wt_data/startup_presets/" 2>/dev/null || true
    copied=$((copied + 1))
  fi

  # Write snapshot metadata
  cat > "$wt_data/.snapshot_meta" <<META
snapshot_date=$(date -u +%Y-%m-%dT%H:%M:%SZ)
source_dir=$main_data
source_project=$_MAIN_ROOT
META

  log "[worktree-start] Snapshot: $copied items copied from main"
}

cmd_worktree_start() {
  # Detect if we're in a worktree
  if ! _detect_worktree_context; then
    err "[worktree-start] Not in a git worktree. Run from a worktree directory."
    err "[worktree-start] Create one with: vnx_worktree_setup.sh create <name>"
    return 1
  fi

  local wt_data="$_WT_ROOT/.vnx-data"
  local main_data="$_MAIN_ROOT/.vnx-data"

  # Check if main has .vnx-data
  if [ ! -d "$main_data" ]; then
    err "[worktree-start] Main repo has no .vnx-data at: $main_data"
    err "[worktree-start] Run 'vnx init' in the main repo first."
    return 1
  fi

  # If .vnx-data is a symlink (old model), remove it first
  if [ -L "$wt_data" ]; then
    log "[worktree-start] Removing old symlink: $wt_data → $(readlink "$wt_data")"
    rm "$wt_data"
  fi

  # Create isolated .vnx-data directory
  if [ -d "$wt_data" ] && [ -f "$wt_data/.snapshot_meta" ]; then
    log "[worktree-start] Worktree already initialized: $wt_data"
    log "[worktree-start] Use 'vnx worktree-refresh' to update intelligence snapshot."
    return 0
  fi

  log "[worktree-start] Initializing isolated .vnx-data for worktree: $_WT_ROOT"

  # Create directory structure (reuse ensure_runtime_layout via env override)
  export VNX_DATA_DIR="$wt_data"
  export VNX_STATE_DIR="$wt_data/state"
  export VNX_DISPATCH_DIR="$wt_data/dispatches"
  export VNX_LOGS_DIR="$wt_data/logs"
  export VNX_PIDS_DIR="$wt_data/pids"
  export VNX_LOCKS_DIR="$wt_data/locks"
  export VNX_REPORTS_DIR="$wt_data/unified_reports"
  export VNX_DB_DIR="$wt_data/database"
  ensure_runtime_layout

  # Hydrate intelligence: prefer git-tracked .vnx-intelligence/ (already in worktree via git),
  # fall back to snapshot from main's .vnx-data/ for projects without .vnx-intelligence/.
  if [ -d "$_WT_ROOT/.vnx-intelligence/db_export" ]; then
    log "[worktree-start] Found .vnx-intelligence/ in worktree — importing into SQLite..."
    if ! cmd_intelligence_import; then
      log "[worktree-start] WARN: intelligence import failed, falling back to snapshot"
      _snapshot_intelligence "$main_data" "$wt_data"
    fi
  else
    _snapshot_intelligence "$main_data" "$wt_data"
  fi

  # Write .env_override (Option 3B: auto-generated)
  cat > "$wt_data/.env_override" <<OVERRIDE
# Auto-generated by vnx worktree-start ($(date -u +%Y-%m-%dT%H:%M:%SZ))
# Worktree: $_WT_ROOT
# Main repo: $_MAIN_ROOT
export VNX_DATA_DIR='$wt_data'
OVERRIDE

  # Create inbox directory on main for optional receipt relay
  mkdir -p "$main_data/inbox"

  log "[worktree-start] Isolated .vnx-data created: $wt_data"
  log "[worktree-start] .env_override written for VNX_DATA_DIR isolation"
  log "[worktree-start] Done. Run 'vnx doctor' to verify."
}

cmd_worktree_stop() {
  local merge_only=false
  local skip_merge=false
  while [ $# -gt 0 ]; do
    case "$1" in
      --merge-only) merge_only=true; shift ;;
      --skip-merge) skip_merge=true; shift ;;
      *) err "[worktree-stop] Unknown option: $1"; return 1 ;;
    esac
  done

  if ! _detect_worktree_context; then
    err "[worktree-stop] Not in a git worktree."
    return 1
  fi

  local wt_data="$_WT_ROOT/.vnx-data"
  local main_data="$_MAIN_ROOT/.vnx-data"

  if [ ! -d "$wt_data" ] || [ -L "$wt_data" ]; then
    err "[worktree-stop] No isolated .vnx-data found in worktree."
    return 1
  fi

  # Export intelligence: prefer git-tracked .vnx-intelligence/ export, fall back to merge script.
  if [ "$skip_merge" = false ]; then
    if [ -d "$_WT_ROOT/.vnx-intelligence" ] || [ -f "$wt_data/state/quality_intelligence.db" ]; then
      log "[worktree-stop] Exporting intelligence to .vnx-intelligence/..."
      if ! cmd_intelligence_export; then
        log "[worktree-stop] WARN: intelligence export failed, falling back to merge script"
        local merge_script="$VNX_HOME/scripts/vnx_worktree_merge_data.sh"
        if [ -f "$merge_script" ]; then
          bash "$merge_script" "$wt_data"
        fi
      fi
    else
      # Fallback: use legacy merge script for projects without .vnx-intelligence/
      local merge_script="$VNX_HOME/scripts/vnx_worktree_merge_data.sh"
      if [ -f "$merge_script" ]; then
        log "[worktree-stop] Merging intelligence data back to main..."
        bash "$merge_script" "$wt_data"
      else
        err "[worktree-stop] Merge script not found: $merge_script"
        err "[worktree-stop] Data preserved in: $wt_data"
        return 1
      fi
    fi

    # Clean up inbox relay files on main
    local wt_name
    wt_name="$(basename "$_WT_ROOT")"
    rm -f "$main_data/inbox/wt-${wt_name}.ndjson" 2>/dev/null || true
  fi

  if [ "$merge_only" = true ]; then
    log "[worktree-stop] Merge complete (--merge-only). Data preserved in: $wt_data"
    return 0
  fi

  # Clean up worktree .vnx-data
  log "[worktree-stop] Cleaning up worktree .vnx-data..."
  rm -rf "$wt_data"

  log "[worktree-stop] Done. Worktree intelligence merged to main."
}

cmd_worktree_refresh() {
  if ! _detect_worktree_context; then
    err "[worktree-refresh] Not in a git worktree."
    return 1
  fi

  local wt_data="$_WT_ROOT/.vnx-data"
  local main_data="$_MAIN_ROOT/.vnx-data"

  if [ ! -d "$wt_data" ] || [ -L "$wt_data" ]; then
    err "[worktree-refresh] No isolated .vnx-data found. Run 'vnx worktree-start' first."
    return 1
  fi

  if [ ! -d "$main_data" ]; then
    err "[worktree-refresh] Main repo .vnx-data not found: $main_data"
    return 1
  fi

  log "[worktree-refresh] Updating intelligence snapshot from main..."
  _snapshot_intelligence "$main_data" "$wt_data"
  log "[worktree-refresh] Done. Intelligence snapshot updated."
}

cmd_worktree_status() {
  log "VNX Worktree Status"
  log "==================="
  log ""

  # Show current context
  if _detect_worktree_context; then
    log "Current: WORKTREE ($_WT_ROOT)"
    log "Main:    $_MAIN_ROOT"
    local wt_data="$_WT_ROOT/.vnx-data"
    if [ -L "$wt_data" ]; then
      log "Data:    SYMLINKED (old model) → $(readlink "$wt_data")"
      log "         WARNING: Run 'vnx worktree-start' to migrate to isolated model"
    elif [ -d "$wt_data" ] && [ -f "$wt_data/.snapshot_meta" ]; then
      local snap_date
      snap_date=$(grep '^snapshot_date=' "$wt_data/.snapshot_meta" 2>/dev/null | cut -d= -f2)
      log "Data:    ISOLATED (snapshot: ${snap_date:-unknown})"
    elif [ -d "$wt_data" ]; then
      log "Data:    DIRECTORY (no snapshot metadata)"
    else
      log "Data:    NONE — run 'vnx worktree-start'"
    fi
  else
    log "Current: MAIN REPO ($PROJECT_ROOT)"
  fi

  log ""

  # List all VNX-managed worktrees
  log "Worktrees:"
  local wt_list
  wt_list="$(git -C "$PROJECT_ROOT" worktree list 2>/dev/null)" || true
  if [ -z "$wt_list" ]; then
    log "  (none)"
    return 0
  fi

  echo "$wt_list" | while IFS= read -r line; do
    local wt_path
    wt_path="$(echo "$line" | awk '{print $1}')"
    local wt_branch
    wt_branch="$(echo "$line" | sed 's/.*\[//' | sed 's/\]//')"

    # Check isolation status
    local status_icon="?"
    local wt_vnx_data="$wt_path/.vnx-data"
    if [ -L "$wt_vnx_data" ]; then
      status_icon="SYMLINK"
    elif [ -d "$wt_vnx_data" ] && [ -f "$wt_vnx_data/.snapshot_meta" ]; then
      status_icon="ISOLATED"
    elif [ -d "$wt_vnx_data" ]; then
      status_icon="DIR"
    else
      status_icon="NONE"
    fi

    log "  $wt_path [$wt_branch] data=$status_icon"
  done
}

# ── vnx update ─────────────────────────────────────────────────────────
VNX_ORIGIN_URL="https://github.com/Vinix24/vnx-orchestration-system.git"
VNX_ORIGIN_FILE="$VNX_HOME/.vnx-origin"
VNX_VERSION_LOCK="$VNX_HOME/version.lock"

cmd_update() {
  local origin_url branch="main"
  local do_pin=""
  local do_check=false
  local ignore_lock=false
  local positional=()

  # Parse flags
  while [ $# -gt 0 ]; do
    case "$1" in
      --pin)
        do_pin="$2"; shift 2
        ;;
      --pin=*)
        do_pin="${1#*=}"; shift
        ;;
      --check)
        do_check=true; shift
        ;;
      --latest)
        ignore_lock=true; shift
        ;;
      *)
        positional+=("$1"); shift
        ;;
    esac
  done

  # Handle --pin: just write the lock file and exit
  if [ -n "$do_pin" ]; then
    echo "$do_pin" > "$VNX_VERSION_LOCK"
    log "[update] Version pinned to: $do_pin"
    log "[update] Lock file: $VNX_VERSION_LOCK"
    return 0
  fi

  # Resolve origin: positional arg > .vnx-origin file > default
  if [ "${#positional[@]}" -ge 1 ]; then
    origin_url="${positional[0]}"
  elif [ -f "$VNX_ORIGIN_FILE" ]; then
    origin_url="$(head -1 "$VNX_ORIGIN_FILE" | tr -d '[:space:]')"
  else
    origin_url="$VNX_ORIGIN_URL"
  fi

  if [ "${#positional[@]}" -ge 2 ]; then
    branch="${positional[1]}"
  fi

  # Respect version lock (unless --latest)
  if [ "$ignore_lock" = false ] && [ -f "$VNX_VERSION_LOCK" ]; then
    local locked_version
    locked_version="$(head -1 "$VNX_VERSION_LOCK" | tr -d '[:space:]')"
    if [ -n "$locked_version" ]; then
      branch="$locked_version"
      log "[update] Using pinned version: $locked_version (from version.lock)"
      log "[update] Use --latest to ignore the lock."
    fi
  fi

  # Handle --check: dry-run
  if [ "$do_check" = true ]; then
    log "[update] Check mode (dry-run)"
    log "[update] Origin: $origin_url"
    log "[update] Branch/tag: $branch"
    if [ -f "$VNX_VERSION_LOCK" ]; then
      log "[update] Version lock: $(head -1 "$VNX_VERSION_LOCK" | tr -d '[:space:]')"
    else
      log "[update] Version lock: none"
    fi
    # Try to fetch remote refs to show available version
    local remote_sha
    remote_sha="$(git ls-remote "$origin_url" "$branch" 2>/dev/null | head -1 | cut -f1)" || true
    if [ -n "$remote_sha" ]; then
      log "[update] Remote SHA: ${remote_sha:0:12}"
    else
      log "[update] Remote: unable to fetch (check network/URL)"
    fi
    return 0
  fi

  log "[update] Pulling latest VNX from: $origin_url (branch: $branch)"

  local tmpdir
  tmpdir="$(mktemp -d)"
  trap 'rm -rf "$tmpdir"' EXIT

  if ! git clone --depth 1 --branch "$branch" "$origin_url" "$tmpdir" 2>/dev/null; then
    err "Failed to clone $origin_url (branch: $branch)"
    return 1
  fi

  local install_script="$tmpdir/install.sh"
  if [ ! -f "$install_script" ]; then
    err "No install.sh found in repo root"
    return 1
  fi

  log "[update] Installing to: $PROJECT_ROOT"
  bash "$install_script" "$PROJECT_ROOT"

  # Persist origin for future updates
  echo "$origin_url" > "$VNX_ORIGIN_FILE"

  log "[update] Done. Run 'vnx doctor' to verify."
}

main() {
  local cmd="${1:-help}"
  shift || true

  # Load external command file if available. This sources the cmd_<name>()
  # function from scripts/commands/<name>.sh, overriding any inline definition.
  _load_command "$cmd" 2>/dev/null || true

  # PR-2: Mode gating — check if command is allowed in current mode.
  _check_mode_gate "$cmd" || exit 1

  case "$cmd" in
    init)
      cmd_init "$@"
      ;;
    init-db)
      cmd_init_db
      ;;
    bootstrap-skills)
      cmd_bootstrap_skills
      ;;
    bootstrap-terminals)
      cmd_bootstrap_terminals "$@"
      ;;
    bootstrap-hooks)
      cmd_bootstrap_hooks
      ;;
    regen-settings)
      cmd_regen_settings "$@"
      ;;
    start)
      cmd_start "$@"
      ;;
    stop)
      cmd_stop
      ;;
    doctor)
      cmd_doctor "$@"
      ;;
    smoke)
      cmd_smoke "$@"
      ;;
    cost-report)
      cmd_cost_report "$@"
      ;;
    package-check)
      cmd_package_check
      ;;
    update)
      cmd_update "$@"
      ;;
    intelligence-export)
      cmd_intelligence_export
      ;;
    intelligence-import)
      cmd_intelligence_import
      ;;
    analyze-sessions)
      python3 "$VNX_HOME/scripts/conversation_analyzer.py" "$@"
      ;;
    new-worktree)
      cmd_new_worktree "$@"
      ;;
    merge-preflight)
      cmd_merge_preflight "$@"
      ;;
    finish-worktree)
      cmd_finish_worktree "$@"
      ;;
    worktree-start)
      cmd_worktree_start
      ;;
    worktree-stop)
      cmd_worktree_stop "$@"
      ;;
    worktree-refresh)
      cmd_worktree_refresh
      ;;
    worktree-status)
      cmd_worktree_status
      ;;
    snapshot)
      cmd_snapshot "$@"
      ;;
    restore)
      cmd_restore "$@"
      ;;
    quiesce-check)
      cmd_quiesce_check "$@"
      ;;
    pause)
      cmd_pause "$@"
      ;;
    resume)
      cmd_resume "$@"
      ;;
    recover)
      cmd_recover "$@"
      ;;
    patch-agent-files)
      cmd_patch_agent_files
      ;;
    staging-list)
      python3 "$VNX_HOME/scripts/pr_queue_manager.py" staging-list "$@"
      ;;
    promote)
      python3 "$VNX_HOME/scripts/pr_queue_manager.py" promote "$@"
      ;;
    init-feature)
      python3 "$VNX_HOME/scripts/pr_queue_manager.py" init-feature "$@"
      ;;
    queue-status)
      python3 "$VNX_HOME/scripts/pr_queue_manager.py" queue-status "$@"
      ;;
    suggest)
      python3 "$VNX_HOME/scripts/apply_suggested_edits.py" "$@"
      ;;
    insights)
      python3 "$VNX_HOME/scripts/vnx_insights_cli.py" "$@"
      ;;
    gate-check)
      python3 "$VNX_HOME/scripts/pre_merge_gate.py" "$@"
      ;;
    dispatch)
      cmd_dispatch "$@"
      ;;
    gate)
      cmd_gate "$@"
      ;;
    roadmap)
      cmd_roadmap "$@"
      ;;
    status)
      cmd_status "$@"
      ;;
    ps)
      python3 "$VNX_HOME/scripts/vnx_process_ux.py" ps "$@"
      ;;
    cleanup)
      python3 "$VNX_HOME/scripts/vnx_process_ux.py" cleanup "$@"
      ;;
    restart)
      python3 "$VNX_HOME/scripts/vnx_process_ux.py" restart "$@"
      ;;
    jump)
      cmd_jump "$@"
      ;;
    register)
      cmd_register "$@"
      ;;
    list-projects)
      cmd_list_projects
      ;;
    unregister)
      cmd_unregister "$@"
      ;;
    install-git-hooks)
      cmd_install_git_hooks
      ;;
    uninstall-git-hooks)
      cmd_uninstall_git_hooks
      ;;
    install-shell-helper)
      bash "$VNX_HOME/scripts/vnx_shell_helper.sh" "$@"
      ;;
    setup)
      PYTHONPATH="$VNX_HOME/scripts/lib:${PYTHONPATH:-}" python3 "$VNX_HOME/scripts/vnx_setup.py" "$@"
      ;;
    install-check)
      PYTHONPATH="$VNX_HOME/scripts/lib:${PYTHONPATH:-}" python3 "$VNX_HOME/scripts/vnx_install.py" --check "$@"
      ;;
    install-validate)
      PYTHONPATH="$VNX_HOME/scripts/lib:${PYTHONPATH:-}" python3 "$VNX_HOME/scripts/vnx_install.py" --validate "$@"
      ;;
    demo)
      cmd_demo "$@"
      ;;
    pool)
      PYTHONPATH="$VNX_HOME/scripts/lib:${PYTHONPATH:-}" exec python3 -m vnx_cli.commands.pool "$@"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      err "Unknown command: $cmd"
      usage
      exit 1
      ;;
  esac
}

main "$@"
