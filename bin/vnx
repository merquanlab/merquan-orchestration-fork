#!/usr/bin/env bash
# VNX Bootstrap CLI (Phase P2)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export VNX_BIN="$SCRIPT_DIR/$(basename "${BASH_SOURCE[0]}")"
export VNX_EXECUTABLE="$VNX_BIN"

# CRITICAL: Always compute PROJECT_ROOT from script location.
# Never inherit from environment — prevents cross-project contamination
# (e.g. SEOcrawler PROJECT_ROOT leaking into marketing-magic-circle).
# Preserve VNX_DATA_DIR if explicitly set (worktree isolation)
_VNX_SAVED_DATA_DIR="${VNX_DATA_DIR:-}"
unset PROJECT_ROOT VNX_HOME VNX_DATA_DIR VNX_STATE_DIR VNX_DISPATCH_DIR
[ -n "$_VNX_SAVED_DATA_DIR" ] && export VNX_DATA_DIR="$_VNX_SAVED_DATA_DIR"
unset _VNX_SAVED_DATA_DIR

if [ -f "$SCRIPT_DIR/../scripts/lib/vnx_paths.sh" ]; then
  # shellcheck source=/dev/null
  source "$SCRIPT_DIR/../scripts/lib/vnx_paths.sh"
else
  VNX_HOME_DEFAULT="$(cd "$SCRIPT_DIR/.." && pwd)"
  if [ "$(basename "$VNX_HOME_DEFAULT")" = "vnx-system" ] && [ "$(basename "$(dirname "$VNX_HOME_DEFAULT")")" = ".claude" ]; then
    PROJECT_ROOT_DEFAULT="$(cd "$VNX_HOME_DEFAULT/../.." && pwd)"
  elif git -C "$VNX_HOME_DEFAULT" rev-parse --show-toplevel >/dev/null 2>&1 && [ "$(git -C "$VNX_HOME_DEFAULT" rev-parse --show-toplevel 2>/dev/null)" = "$VNX_HOME_DEFAULT" ]; then
    PROJECT_ROOT_DEFAULT="$VNX_HOME_DEFAULT"
  else
    PROJECT_ROOT_DEFAULT="$(cd "$VNX_HOME_DEFAULT/.." && pwd)"
  fi
  VNX_CANONICAL_ROOT_DEFAULT="$(git -C "$VNX_HOME_DEFAULT" rev-parse --path-format=absolute --git-common-dir 2>/dev/null | sed 's|/\.git$||')" || VNX_CANONICAL_ROOT_DEFAULT="$VNX_HOME_DEFAULT"
  [ -n "$VNX_CANONICAL_ROOT_DEFAULT" ] || VNX_CANONICAL_ROOT_DEFAULT="$VNX_HOME_DEFAULT"

  export VNX_HOME="${VNX_HOME:-$VNX_HOME_DEFAULT}"
  export PROJECT_ROOT="${PROJECT_ROOT:-$PROJECT_ROOT_DEFAULT}"
  export VNX_CANONICAL_ROOT="${VNX_CANONICAL_ROOT:-$VNX_CANONICAL_ROOT_DEFAULT}"
  export VNX_DATA_DIR="${VNX_DATA_DIR:-$PROJECT_ROOT/.vnx-data}"
  export VNX_STATE_DIR="${VNX_STATE_DIR:-$VNX_DATA_DIR/state}"
  export VNX_DISPATCH_DIR="${VNX_DISPATCH_DIR:-$VNX_DATA_DIR/dispatches}"
  export VNX_LOGS_DIR="${VNX_LOGS_DIR:-$VNX_DATA_DIR/logs}"
  export VNX_PIDS_DIR="${VNX_PIDS_DIR:-$VNX_DATA_DIR/pids}"
  export VNX_LOCKS_DIR="${VNX_LOCKS_DIR:-$VNX_DATA_DIR/locks}"
  export VNX_REPORTS_DIR="${VNX_REPORTS_DIR:-$VNX_DATA_DIR/unified_reports}"
  export VNX_DB_DIR="${VNX_DB_DIR:-$VNX_DATA_DIR/database}"
  export VNX_INTELLIGENCE_DIR="${VNX_INTELLIGENCE_DIR:-$VNX_CANONICAL_ROOT/.vnx-intelligence}"

  if [ -d "$PROJECT_ROOT_DEFAULT/.claude/skills" ]; then
    export VNX_SKILLS_DIR="$PROJECT_ROOT_DEFAULT/.claude/skills"
  else
    export VNX_SKILLS_DIR="${VNX_SKILLS_DIR:-$VNX_HOME_DEFAULT/skills}"
  fi
fi

# Worktree env override: if CWD has .vnx-data/.env_override, source it
_vnx_cwd_override="$(pwd)/.vnx-data/.env_override"
if [ -f "$_vnx_cwd_override" ]; then
  # shellcheck source=/dev/null
  source "$_vnx_cwd_override"
  export VNX_STATE_DIR="$VNX_DATA_DIR/state"
  export VNX_DISPATCH_DIR="$VNX_DATA_DIR/dispatches"
  export VNX_LOGS_DIR="$VNX_DATA_DIR/logs"
  export VNX_PIDS_DIR="$VNX_DATA_DIR/pids"
  export VNX_LOCKS_DIR="$VNX_DATA_DIR/locks"
  export VNX_REPORTS_DIR="$VNX_DATA_DIR/unified_reports"
  export VNX_DB_DIR="$VNX_DATA_DIR/database"
fi
unset _vnx_cwd_override

if [ -f "$SCRIPT_DIR/../scripts/lib/vnx_marked_blocks.sh" ]; then
  # shellcheck source=/dev/null
  source "$SCRIPT_DIR/../scripts/lib/vnx_marked_blocks.sh"
fi

VNX_CONFIG_DIR="${PROJECT_ROOT}/.vnx"
VNX_CONFIG_FILE="${VNX_CONFIG_DIR}/config.yml"
TERMINALS_TEMPLATE_DIR="${VNX_HOME}/templates/terminals"
SNIPPETS_TEMPLATE_DIR="${VNX_HOME}/templates/snippets"

MARKER_BEGIN="<!-- VNX:BEGIN BOOTSTRAP -->"
MARKER_END="<!-- VNX:END BOOTSTRAP -->"

log() {
  printf '%s\n' "$*"
}

err() {
  printf 'ERROR: %s\n' "$*" >&2
}

# ── Command loader ──────────────────────────────────────────────────────
# Sources an external command file from scripts/commands/<name>.sh if it exists.
# The sourced file defines the cmd_<name>() function which the main dispatch
# then calls. This allows new commands to be added as separate files without
# growing bin/vnx further.
#
# Usage: _load_command <name>
# Returns 0 if the command file was sourced, 1 if not found.
VNX_COMMANDS_DIR="${VNX_HOME}/scripts/commands"

_load_command() {
  local name="$1"
  local cmd_file="${VNX_COMMANDS_DIR}/${name}.sh"
  if [ -f "$cmd_file" ]; then
    # shellcheck source=/dev/null
    source "$cmd_file"
    return 0
  fi
  # Try underscore variant (e.g. new-worktree -> new_worktree.sh)
  local underscore_name="${name//-/_}"
  if [ "$underscore_name" != "$name" ]; then
    cmd_file="${VNX_COMMANDS_DIR}/${underscore_name}.sh"
    if [ -f "$cmd_file" ]; then
      # shellcheck source=/dev/null
      source "$cmd_file"
      return 0
    fi
  fi
  return 1
}

  usage() {
    cat <<USAGE
Usage: vnx <command>

Commands:
  init               Create .vnx-data runtime layout and .vnx/config.yml
  init-db            Initialize quality intelligence database from schema
  bootstrap-skills   Create/link ./\.claude/skills from shipped dist skills
  bootstrap-terminals  Create ./\.claude/terminals (default: T0..T3)
  bootstrap-hooks    Deploy SessionStart hooks to .claude/hooks/ + settings.json
  regen-settings     Patch-manage settings.json (--merge|--full|--validate)
  start [--profile X] Launch VNX tmux session (interactive profile selection)
                     Profiles: claude-only, claude-codex, claude-gemini, full-multi
  start --preset <name>  Start with a saved startup preset
  start --last           Start with last-used startup configuration
  stop               Stop VNX tmux session and orchestration processes
  doctor             Validate layout, dependencies, and path hygiene
  smoke              Run one-shot local receipt pipeline smoke test
  cost-report        Aggregate model usage + estimated cost from receipts
  package-check      Fail if runtime artifacts exist inside dist
  update [url] [branch]  Pull latest VNX from origin and re-install
  update --pin <tag>     Pin VNX version (respects lock on future updates)
  update --check         Dry-run: show current vs available version
  update --latest        Update ignoring version.lock
  patch-agent-files  Insert/update VNX marked block in CLAUDE.md / AGENTS.md
  suggest <sub>      Human-in-the-loop system tuning (review/accept/reject/apply/history)
                       review --weekly  Aggregate last 7d suggestions by target file
  insights           Read-only F57 dispatch parameter + behavioral intelligence signals
                       --json           Machine-readable JSON output

Intelligence commands (git-tracked project knowledge):
  intelligence-export  Export SQLite + state to canonical .vnx-intelligence/ (NDJSON)
  intelligence-import  Import canonical .vnx-intelligence/ NDJSON into SQLite
  analyze-sessions     Mine Claude Code session logs → session_analytics DB
                       Options: --dry-run, --max-sessions N, --deep-budget N,
                                --project-filter STR, --terminal-filter T0..T3

Worktree commands:
  new-worktree <name>  Create fully bootstrapped feature worktree (one command)
                     Options: --branch, --base, --preset, --skip-doctor
  merge-preflight <name>  Governance check: GO or NO-GO verdict for worktree merge
  finish-worktree <name>  Close worktree with governance gates + intelligence merge
                     Options: --delete-branch, --force
  worktree-start     Initialize isolated .vnx-data with intelligence snapshot
  worktree-stop      Merge intelligence back to main and clean up
  worktree-refresh   Update intelligence snapshot from main
  worktree-status    Show worktree isolation status

Pool commands (elastic worker pool management):
  pool status [--project <id>] [--pool-id <p>] [--json]  Show pool state
  pool scale --project <id> --to <N>                     Force scale to N workers
  pool config --project <id> [--min N] [--max N] [--policy <name>] [--cooldown <s>]
  pool reap --project <id> [--pool-id <p>] [--force]     Reap stale workers

Gate commands (pre-merge verification):
  gate-check --pr <ID>  Run deterministic pre-merge gate checks (GO/HOLD verdict)
  roadmap <sub>       Roadmap orchestration and auto-next feature loading

Process commands (visibility and control):
  status             Show terminal health, dispatch queue, and gate results
  status --terminals   Just terminal health
  status --dispatches  Just dispatch queue
  status --gates       Just gate results
  status --json        Machine-readable JSON output
  ps [--json]        Show PID, parent PID, uptime, and health for VNX processes
  cleanup [--dry-run]  Remove orphan PIDs and stale locks
  restart <process>  Restart a managed VNX process
  jump <terminal>    Switch tmux focus to T0/T1/T2/T3 pane
  jump --attention   Jump to highest-priority terminal needing attention

Dispatch commands (one-liner delivery):
  dispatch <file.md>              Auto-detect terminal and deliver dispatch
  dispatch <file.md> --terminal T1  Override terminal
  dispatch <file.md> --model opus   Override model
  dispatch <file.md> --dry-run      Preview without delivering

Gate commands (pre-merge verification):
  gate <pr>                Run all required gates (from governance_enforcement.yaml)
  gate <pr> --only codex   Run only the Codex gate
  gate <pr> --only gemini  Run only the Gemini review gate
  gate <pr> --status       Show gate results without running

Snapshot commands (W0):
  snapshot [<path>]         Snapshot .vnx-data/ to ~/vnx-snapshots/ (tarball + SQL dump)
  restore <tarball>         Restore .vnx-data/ from snapshot tarball
                            Options: --target <path>, --force
  quiesce-check [<path>]    Verify project is safe to migrate (read-only)

Runtime commands:
  pause [reason]     Gracefully stop dispatcher + receipt_processor + queue_watcher
                     Writes ${VNX_STATE_DIR}/PAUSED marker for migration cutover
  resume             Restart daemons after 'vnx pause'; fails if not paused
  recover            Recover from unclean shutdown or stale state
                     Options: --aggressive, --dry-run

Project registry:
  register [path] [name]  Register project in ~/.vnx/projects.json
  list-projects           List all registered VNX projects
  unregister [path]       Remove project from registry

Shell helper:
  install-shell-helper    Add vnx() function to shell RC (~/.zshrc or ~/.bashrc)
                     Options: --print, --uninstall, --shell bash|zsh

  setup              One-command project setup (init + doctor + register)
                     Options: --starter (default), --operator, --skip-doctor
  install-check      Check prerequisites without installing
  install-validate   Validate an existing VNX installation

  demo               Showcase VNX without API keys or project setup
                     Sub-commands: replay [scenario], dashboard, setup, list
  demo --replay <scenario>  Replay a recorded governance flow
  demo --dashboard          Launch dashboard with sample data

  help               Show this help text
USAGE
  }

ensure_runtime_layout() {
  mkdir -p "$VNX_DATA_DIR" \
    "$VNX_STATE_DIR" \
    "$VNX_LOGS_DIR" \
    "$VNX_PIDS_DIR" \
    "$VNX_LOCKS_DIR" \
    "$VNX_DISPATCH_DIR/pending" \
    "$VNX_DISPATCH_DIR/active" \
    "$VNX_DISPATCH_DIR/completed" \
    "$VNX_DISPATCH_DIR/rejected" \
    "$VNX_DISPATCH_DIR/failed" \
    "$VNX_REPORTS_DIR" \
    "$VNX_DB_DIR" \
    "$VNX_DATA_DIR/receipts" \
    "$VNX_DATA_DIR/profiles" \
    "$VNX_DATA_DIR/startup_presets"

  # Write provider profiles if they don't exist yet (idempotent).
  _write_profiles_if_missing "$VNX_DATA_DIR/profiles"

  # Write default startup presets if they don't exist yet (idempotent).
  _write_default_presets_if_missing "$VNX_DATA_DIR/startup_presets"
}

_write_profiles_if_missing() {
  local dir="$1"

  # claude-only: all terminals run Claude Code
  if [ ! -f "$dir/claude-only.env" ]; then
    cat > "$dir/claude-only.env" <<'ENV'
# VNX Profile: claude-only
# All worker terminals use Claude Code (claude).
VNX_T1_PROVIDER=claude_code
VNX_T2_PROVIDER=claude_code
ENV
  fi

  # claude-codex: T1 uses Codex CLI, T2 uses Claude Code
  if [ ! -f "$dir/claude-codex.env" ]; then
    cat > "$dir/claude-codex.env" <<'ENV'
# VNX Profile: claude-codex
# T1 uses Codex CLI, T2 uses Claude Code.
VNX_T1_PROVIDER=codex_cli
VNX_T2_PROVIDER=claude_code
ENV
  fi

  # claude-gemini: T1 uses Gemini CLI, T2 uses Claude Code
  if [ ! -f "$dir/claude-gemini.env" ]; then
    cat > "$dir/claude-gemini.env" <<'ENV'
# VNX Profile: claude-gemini
# T1 uses Gemini CLI, T2 uses Claude Code.
VNX_T1_PROVIDER=gemini_cli
VNX_T2_PROVIDER=claude_code
ENV
  fi

  # full-multi: T1 uses Codex CLI, T2 uses Gemini CLI
  if [ ! -f "$dir/full-multi.env" ]; then
    cat > "$dir/full-multi.env" <<'ENV'
# VNX Profile: full-multi
# T1 uses Codex CLI, T2 uses Gemini CLI.
VNX_T1_PROVIDER=codex_cli
VNX_T2_PROVIDER=gemini_cli
ENV
  fi
}

_write_default_presets_if_missing() {
  local dir="$1"

  if [ ! -f "$dir/full-auto.env" ]; then
    cat > "$dir/full-auto.env" <<'ENV'
# Preset: full-auto
# All Claude, skip-permissions on all workers
VNX_T0_PROVIDER=claude_code
VNX_T1_PROVIDER=claude_code
VNX_T2_PROVIDER=claude_code
VNX_T3_PROVIDER=claude_code
VNX_T0_SKIP_PERMISSIONS=0
VNX_T1_SKIP_PERMISSIONS=1
VNX_T2_SKIP_PERMISSIONS=1
VNX_T3_SKIP_PERMISSIONS=1
VNX_QUEUE_POPUP_ENABLED=0
ENV
  fi

  if [ ! -f "$dir/review-mode.env" ]; then
    cat > "$dir/review-mode.env" <<'ENV'
# Preset: review-mode
# All Claude, no skip-permissions (manual approval)
VNX_T0_PROVIDER=claude_code
VNX_T1_PROVIDER=claude_code
VNX_T2_PROVIDER=claude_code
VNX_T3_PROVIDER=claude_code
VNX_T0_SKIP_PERMISSIONS=0
VNX_T1_SKIP_PERMISSIONS=0
VNX_T2_SKIP_PERMISSIONS=0
VNX_T3_SKIP_PERMISSIONS=0
VNX_QUEUE_POPUP_ENABLED=0
ENV
  fi

  if [ ! -f "$dir/claude-codex-auto.env" ]; then
    cat > "$dir/claude-codex-auto.env" <<'ENV'
# Preset: claude-codex-auto
# T1=Codex, T2=Claude, skip-permissions on T1
VNX_T0_PROVIDER=claude_code
VNX_T1_PROVIDER=codex_cli
VNX_T2_PROVIDER=claude_code
VNX_T3_PROVIDER=claude_code
VNX_T0_SKIP_PERMISSIONS=0
VNX_T1_SKIP_PERMISSIONS=1
VNX_T2_SKIP_PERMISSIONS=1
VNX_T3_SKIP_PERMISSIONS=0
VNX_QUEUE_POPUP_ENABLED=0
ENV
  fi
}

# ── Interactive Startup Menu ─────────────────────────────────────────────────
# Presents saved presets and custom per-terminal configuration.
# Sets VNX_T{0..3}_PROVIDER, VNX_T{0..3}_SKIP_PERMISSIONS, VNX_QUEUE_POPUP_ENABLED.
# Returns 0 on success, 1 on abort.
_interactive_startup_menu() {
  local presets_dir="$1"
  mkdir -p "$presets_dir"

  # Collect available presets
  local -a preset_files preset_names preset_descs
  local i=0

  # Always show last-used first if it exists
  local last_used_target=""
  if [ -L "$presets_dir/last-used.env" ] && [ -f "$presets_dir/last-used.env" ]; then
    last_used_target="$(readlink "$presets_dir/last-used.env" 2>/dev/null || true)"
    last_used_target="$(basename "${last_used_target%.env}")"
  fi

  for f in "$presets_dir/"*.env; do
    [ -f "$f" ] || continue
    local bname
    bname="$(basename "${f%.env}")"
    [ "$bname" = "last-used" ] && continue
    preset_files+=("$f")
    preset_names+=("$bname")
    local desc
    desc="$(grep '^# Preset:' "$f" 2>/dev/null | head -1 | sed 's/^# Preset: //')"
    local detail
    detail="$(sed -n '3p' "$f" 2>/dev/null | sed 's/^# //')"
    preset_descs+=("${detail:-$desc}")
    i=$((i + 1))
  done

  echo ""
  echo "  ╔═══════════════════════════════════════════════════╗"
  echo "  ║              VNX Startup Configuration            ║"
  echo "  ╠═══════════════════════════════════════════════════╣"
  echo "  ║                                                   ║"
  echo "  ║  Saved presets:                                   ║"

  local j=1
  for idx in "${!preset_names[@]}"; do
    local marker=""
    [ "${preset_names[$idx]}" = "$last_used_target" ] && marker=" (last)"
    printf "  ║    %d) %-15s %-28s║\n" "$j" "${preset_names[$idx]}${marker}" "${preset_descs[$idx]:0:28}"
    j=$((j + 1))
  done

  echo "  ║    c) Custom configuration...                     ║"
  echo "  ║                                                   ║"
  echo "  ╠═══════════════════════════════════════════════════╣"
  if [ -n "$last_used_target" ]; then
    echo "  ║  Quick start: press Enter for '$last_used_target'     ║"
  else
    echo "  ║  Quick start: press Enter for first preset        ║"
  fi
  echo "  ╚═══════════════════════════════════════════════════╝"
  echo ""
  printf "  Select [1-%d/c]: " "${#preset_names[@]}"
  local choice
  read -r choice

  # Default: load last-used or first preset
  if [ -z "$choice" ]; then
    if [ -n "$last_used_target" ] && [ -f "$presets_dir/last-used.env" ]; then
      source "$presets_dir/last-used.env"
      log "Loaded preset: last-used ($last_used_target)"
      return 0
    elif [ "${#preset_files[@]}" -gt 0 ]; then
      source "${preset_files[0]}"
      _update_last_used "$presets_dir" "${preset_files[0]}"
      log "Loaded preset: ${preset_names[0]}"
      return 0
    fi
  fi

  # Custom configuration
  if [ "$choice" = "c" ] || [ "$choice" = "C" ]; then
    _custom_terminal_config "$presets_dir"
    return $?
  fi

  # Numeric preset selection
  if [ -n "$choice" ] && [ "$choice" -ge 1 ] 2>/dev/null && [ "$choice" -le "${#preset_names[@]}" ] 2>/dev/null; then
    local sel_idx=$((choice - 1))
    source "${preset_files[$sel_idx]}"
    _update_last_used "$presets_dir" "${preset_files[$sel_idx]}"
    log "Loaded preset: ${preset_names[$sel_idx]}"
    return 0
  fi

  echo "  Invalid choice."
  return 1
}

_custom_terminal_config() {
  local presets_dir="$1"

  echo ""
  echo "  Terminal Configuration"
  echo "  ──────────────────────"
  echo "  T0 (Orchestrator):  Claude Opus    [fixed]"

  # T1 provider
  printf "  T1 (Track A):       [1] Claude  [2] Codex  [3] Gemini  → "
  local t1_choice
  read -r t1_choice
  case "$t1_choice" in
    2) export VNX_T1_PROVIDER=codex_cli ;;
    3) export VNX_T1_PROVIDER=gemini_cli ;;
    *) export VNX_T1_PROVIDER=claude_code ;;
  esac

  # T2 provider
  printf "  T2 (Track B):       [1] Claude  [2] Codex  [3] Gemini  → "
  local t2_choice
  read -r t2_choice
  case "$t2_choice" in
    2) export VNX_T2_PROVIDER=codex_cli ;;
    3) export VNX_T2_PROVIDER=gemini_cli ;;
    *) export VNX_T2_PROVIDER=claude_code ;;
  esac

  # T3 provider
  printf "  T3 (Track C):       [1] Claude  [2] Codex  [3] Gemini  → "
  local t3_choice
  read -r t3_choice
  case "$t3_choice" in
    2) export VNX_T3_PROVIDER=codex_cli ;;
    3) export VNX_T3_PROVIDER=gemini_cli ;;
    *) export VNX_T3_PROVIDER=claude_code ;;
  esac

  export VNX_T0_PROVIDER=claude_code

  echo ""
  echo "  Permission Mode"
  echo "  ───────────────"
  printf "  T0: Skip permissions?  [y/N] → "
  local sp0; read -r sp0
  [ "$sp0" = "y" ] || [ "$sp0" = "Y" ] && export VNX_T0_SKIP_PERMISSIONS=1 || export VNX_T0_SKIP_PERMISSIONS=0

  printf "  T1: Skip permissions?  [y/N] → "
  local sp1; read -r sp1
  [ "$sp1" = "y" ] || [ "$sp1" = "Y" ] && export VNX_T1_SKIP_PERMISSIONS=1 || export VNX_T1_SKIP_PERMISSIONS=0

  printf "  T2: Skip permissions?  [y/N] → "
  local sp2; read -r sp2
  [ "$sp2" = "y" ] || [ "$sp2" = "Y" ] && export VNX_T2_SKIP_PERMISSIONS=1 || export VNX_T2_SKIP_PERMISSIONS=0

  printf "  T3: Skip permissions?  [y/N] → "
  local sp3; read -r sp3
  [ "$sp3" = "y" ] || [ "$sp3" = "Y" ] && export VNX_T3_SKIP_PERMISSIONS=1 || export VNX_T3_SKIP_PERMISSIONS=0

  echo ""
  echo "  Queue Popup"
  echo "  ───────────"
  printf "  Enable queue popup watcher? [Y/n] → "
  local qp; read -r qp
  [ "$qp" = "n" ] || [ "$qp" = "N" ] && export VNX_QUEUE_POPUP_ENABLED=0 || export VNX_QUEUE_POPUP_ENABLED=1

  echo ""
  printf "  Save as preset? [name/N] → "
  local save_name
  read -r save_name

  if [ -n "$save_name" ] && [ "$save_name" != "N" ] && [ "$save_name" != "n" ]; then
    local preset_file="$presets_dir/${save_name}.env"
    cat > "$preset_file" <<ENV
# Preset: $save_name
# Custom configuration
VNX_T0_PROVIDER=${VNX_T0_PROVIDER}
VNX_T1_PROVIDER=${VNX_T1_PROVIDER}
VNX_T2_PROVIDER=${VNX_T2_PROVIDER}
VNX_T3_PROVIDER=${VNX_T3_PROVIDER}
VNX_T0_SKIP_PERMISSIONS=${VNX_T0_SKIP_PERMISSIONS}
VNX_T1_SKIP_PERMISSIONS=${VNX_T1_SKIP_PERMISSIONS}
VNX_T2_SKIP_PERMISSIONS=${VNX_T2_SKIP_PERMISSIONS}
VNX_T3_SKIP_PERMISSIONS=${VNX_T3_SKIP_PERMISSIONS}
VNX_QUEUE_POPUP_ENABLED=${VNX_QUEUE_POPUP_ENABLED}
ENV
    log "Preset saved: $preset_file"
    _update_last_used "$presets_dir" "$preset_file"
  else
    # Write a temporary last-used even without saving
    local tmp_file="$presets_dir/_last_custom.env"
    cat > "$tmp_file" <<ENV
# Preset: _last_custom
# Unsaved custom configuration
VNX_T0_PROVIDER=${VNX_T0_PROVIDER}
VNX_T1_PROVIDER=${VNX_T1_PROVIDER}
VNX_T2_PROVIDER=${VNX_T2_PROVIDER}
VNX_T3_PROVIDER=${VNX_T3_PROVIDER}
VNX_T0_SKIP_PERMISSIONS=${VNX_T0_SKIP_PERMISSIONS}
VNX_T1_SKIP_PERMISSIONS=${VNX_T1_SKIP_PERMISSIONS}
VNX_T2_SKIP_PERMISSIONS=${VNX_T2_SKIP_PERMISSIONS}
VNX_T3_SKIP_PERMISSIONS=${VNX_T3_SKIP_PERMISSIONS}
VNX_QUEUE_POPUP_ENABLED=${VNX_QUEUE_POPUP_ENABLED}
ENV
    _update_last_used "$presets_dir" "$tmp_file"
  fi

  return 0
}

_update_last_used() {
  local presets_dir="$1"
  local target_file="$2"
  rm -f "$presets_dir/last-used.env"
  ln -s "$target_file" "$presets_dir/last-used.env"
}

write_default_config_if_missing() {
  mkdir -p "$VNX_CONFIG_DIR"

  if [ -f "$VNX_CONFIG_FILE" ]; then
    log "[init] Keeping existing config: $VNX_CONFIG_FILE"
    return 0
  fi

  cat > "$VNX_CONFIG_FILE" <<CFG
# Generated by vnx init
project_root: "$PROJECT_ROOT"
vnx_home: "$VNX_HOME"
vnx_data_dir: "$VNX_DATA_DIR"
terminals_template_dir: "$TERMINALS_TEMPLATE_DIR"
CFG

  log "[init] Wrote config: $VNX_CONFIG_FILE"
}

cmd_intelligence_export() {
  python3 "$VNX_HOME/scripts/intelligence_export.py"
}

cmd_intelligence_import() {
  python3 "$VNX_HOME/scripts/intelligence_import.py"
}

cmd_init() {
  # Parse --starter / --operator flags before forwarding to Python init.
  local mode_flag=""
  local init_args=()
  for arg in "$@"; do
    case "$arg" in
      --starter)  mode_flag="starter" ;;
      --operator) mode_flag="operator" ;;
      *)          init_args+=("$arg") ;;
    esac
  done

  # PR-1: Python-led init orchestrator (unified bootstrap).
  # Falls back to inline bash if Python entrypoint is unavailable.
  local init_script="$VNX_HOME/scripts/vnx_init.py"
  if command -v python3 >/dev/null 2>&1 && [ -f "$init_script" ]; then
    PYTHONPATH="$VNX_HOME/scripts/lib:${PYTHONPATH:-}" python3 "$init_script" "${init_args[@]+"${init_args[@]}"}"
    local rc=$?
    [ $rc -ne 0 ] && return $rc
  else
    # Legacy fallback (pre-PR-1)
    ensure_runtime_layout
    write_default_config_if_missing

    cmd_bootstrap_skills || true
    cmd_bootstrap_terminals || true
    cmd_bootstrap_hooks || true
    cmd_patch_agent_files || true
    cmd_init_db || true

    if [ -d "$VNX_INTELLIGENCE_DIR/db_export" ]; then
      log "[init] Found intelligence export at $VNX_INTELLIGENCE_DIR — importing into SQLite..."
      cmd_intelligence_import || true
    fi

    log "[init] Runtime root ready: $VNX_DATA_DIR"
  fi

  # PR-2: Write mode.json based on --starter / --operator flag.
  # If no flag given, default to operator (backward compat).
  if [ -z "$mode_flag" ]; then
    mode_flag="operator"
  fi
  if command -v python3 >/dev/null 2>&1; then
    PYTHONPATH="$VNX_HOME/scripts/lib:${PYTHONPATH:-}" python3 -c "
from vnx_mode import VNXMode, write_mode
write_mode(VNXMode('$mode_flag'))
print(f'[init] Mode set: $mode_flag')
"
  fi

  log "[init] Done. Next: vnx doctor"
}

# ── Mode gating ──────────────────────────────────────────────────────────
# PR-2: Check if a command is allowed in the current mode.
# Uses Python vnx_mode.py for mode detection and command tier enforcement.
# Disabled when VNX_MODE_GATING_ENABLED=0 (rollback control).
_check_mode_gate() {
  local cmd="$1"

  # Rollback control: disable gating entirely
  if [ "${VNX_MODE_GATING_ENABLED:-1}" = "0" ]; then
    return 0
  fi

  # Skip gating for init, setup, help, demo (always allowed)
  case "$cmd" in
    init|setup|install-check|install-validate|help|-h|--help|demo) return 0 ;;
  esac

  # Skip if mode.json doesn't exist (pre-init state)
  local mode_file="$VNX_DATA_DIR/mode.json"
  [ -f "$mode_file" ] || return 0

  if command -v python3 >/dev/null 2>&1; then
    PYTHONPATH="$VNX_HOME/scripts/lib:${PYTHONPATH:-}" python3 -c "
import sys
from vnx_mode import check_command_allowed, ModeGateError
try:
    check_command_allowed('$cmd')
except ModeGateError as e:
    print(f'Error: {e}', file=sys.stderr)
    sys.exit(1)
" 2>&1
    return $?
  fi
  return 0
}

# ── Demo command ─────────────────────────────────────────────────────────
cmd_demo() {
  PYTHONPATH="$VNX_HOME/scripts/lib:${PYTHONPATH:-}" python3 "$VNX_HOME/scripts/lib/vnx_demo.py" "$@"
}

cmd_init_db() {
  local db_init_script="$VNX_HOME/scripts/quality_db_init.py"
  local schema_file="$VNX_HOME/schemas/quality_intelligence.sql"
  local db_path="$VNX_STATE_DIR/quality_intelligence.db"

  if [ ! -f "$schema_file" ]; then
    log "[init-db] WARN: Schema file not found: $schema_file (skipping)"
    return 0
  fi

  if [ ! -f "$db_init_script" ]; then
    # Fallback: apply schema directly via sqlite3 if init script missing
    if command -v sqlite3 >/dev/null 2>&1; then
      mkdir -p "$VNX_STATE_DIR"
      sqlite3 "$db_path" < "$schema_file"
      log "[init-db] Database initialized via sqlite3: $db_path"
    else
      log "[init-db] WARN: Neither quality_db_init.py nor sqlite3 available (skipping)"
    fi
    return 0
  fi

  # Use the full Python init script (handles backup, verification, metrics)
  python3 "$db_init_script"
  log "[init-db] Quality intelligence database ready"
}

print_terminal_command() {
  local terminal="$1"
  local template_file="$2"
  local index="$3"

  printf '%s) %s\n' "$index" "$terminal"
  printf '   cd %q && cat %q\n' "$PROJECT_ROOT" "$template_file"
}

# ── Comprehensive orchestration process cleanup ───────────────────────
# Kills ALL VNX orchestration processes for this project. Previous
# versions only killed smart_tap and dispatcher, causing duplicate
# receipt_processors, supervisors, and orphan fswatches that steal
# filesystem events from each other → receipts never delivered to T0.
vnx_kill_all_orchestration() {
  local scripts_dir="$1"
  local log_dir="$2"
  local reason="${3:-session_cleanup}"
  local lifecycle_log="$log_dir/process_lifecycle.log"
  local timeout=3

  # Source process control library for safe pid-checked kills
  if [ -f "$scripts_dir/lib/ops_process_control.sh" ]; then
    # shellcheck disable=SC1090
    source "$scripts_dir/lib/ops_process_control.sh" 2>/dev/null || true
  fi

  # Scope process kills to this project's scripts directory
  export VNX_KILL_SCOPE="$scripts_dir"

  if declare -F vnx_stop_by_fingerprints >/dev/null 2>&1; then
    # Kill each known orchestration process by its script name
    local fp
    for fp in \
      "smart_tap_v7_json_translator.sh" \
      "dispatcher_v8_minimal.sh" \
      "receipt_processor_v4.sh" \
      "vnx_supervisor_simple.sh" \
      "unified_state_manager_v2.py" \
      "generate_valid_dashboard.sh" \
      "intelligence_daemon.py" \
      "heartbeat_ack_monitor.py" \
      "dispatch_ack_watcher.sh" \
      "generate_t0_brief.sh" \
      "queue_popup_watcher.sh" \
      "receipt_notifier.sh" \
      "recommendations_engine_daemon.sh" \
      "gather_intelligence.py" \
      "cached_intelligence.py" \
      "learning_loop.py" \
      "pr_queue_manager.py" \
      "quality_intelligence_db.py" \
    ; do
      vnx_stop_by_fingerprints "$fp" "$lifecycle_log" "$reason" "$timeout" "$fp" || true
    done
  fi

  # Kill legacy orphan fswatch processes watching this project's directories.
  # fswatch is no longer started by receipt_processor (replaced by 5s polling),
  # but orphans from previous versions may still be running.
  local reports_dir="${VNX_REPORTS_DIR:-$VNX_DATA_DIR/unified_reports}"
  local pid cmd
  while IFS= read -r pid; do
    [ -n "$pid" ] || continue
    cmd="$(ps -p "$pid" -o command= 2>/dev/null || true)"
    if [[ "$cmd" == *"$reports_dir"* ]] || [[ "$cmd" == *"$VNX_DATA_DIR"* ]]; then
      kill -TERM "$pid" 2>/dev/null || true
      log "Killed orphan fswatch (PID: $pid)"
    fi
  done < <(pgrep -x fswatch 2>/dev/null || true)

  unset VNX_KILL_SCOPE

  # Broad sweep: kill remaining processes scoped to THIS project's VNX_DATA_DIR.
  # Only kills processes whose command line contains our data dir path,
  # so other worktrees/projects are not affected.
  while IFS= read -r pid; do
    [ -n "$pid" ] || continue
    [ "$pid" != "$$" ] || continue  # Don't kill ourselves
    local _cmd
    _cmd="$(ps -p "$pid" -o args= 2>/dev/null || true)"
    if [[ "$_cmd" == *"$VNX_DATA_DIR"* ]]; then
      kill -TERM "$pid" 2>/dev/null || true
    fi
  done < <(pgrep -f "$scripts_dir" 2>/dev/null || true)

  # Clean up locks and PID files ONLY after all processes have been killed above.
  # This is an operator-initiated teardown path (stop/restart/recover), NOT a
  # steady-state runtime operation. Per A-R10: no blind lock or PID wipe in
  # steady-state paths. This cleanup is safe here because:
  #   1. All orchestration processes were already terminated above
  #   2. This function is only called from explicit operator commands (vnx start/stop/recover)
  #   3. Locks and PIDs are only valid for the processes that held them (now dead)
  if [ -d "${VNX_LOCKS_DIR:-}" ]; then
    rm -rf "$VNX_LOCKS_DIR"/*.lock 2>/dev/null || true
  fi
  if [ -d "${VNX_PIDS_DIR:-}" ]; then
    rm -f "$VNX_PIDS_DIR"/*.pid "$VNX_PIDS_DIR"/*.pid.fingerprint 2>/dev/null || true
  fi

  sleep 1  # Brief pause to let processes exit cleanly
}

build_block_file() {
  vnx_build_block_file "$1" "$2" "$MARKER_BEGIN" "$MARKER_END"
}

upsert_marked_block() {
  local target_file="$1"
  local snippet_file="$2"
  local result

  if ! command -v vnx_upsert_marked_block >/dev/null 2>&1; then
    err "Missing helper: vnx_upsert_marked_block"
    return 1
  fi

  # vnx_upsert_marked_block return codes:
  # 0 => unchanged, 1 => created, 2 => updated.
  if vnx_upsert_marked_block "$target_file" "$snippet_file" "$MARKER_BEGIN" "$MARKER_END"; then
    result=0
  else
    result=$?
  fi

  case "$result" in
    0)
      log "[patch-agent-files] Unchanged: $target_file"
      ;;
    1)
      log "[patch-agent-files] Created: $target_file"
      ;;
    2)
      log "[patch-agent-files] Updated: $target_file"
      ;;
    *)
      err "[patch-agent-files] Failed: $target_file"
      return 1
      ;;
  esac
}

select_snippet_for_target() {
  local target_basename="$1"
  local default_snippet="$SNIPPETS_TEMPLATE_DIR/CLAUDE_SNIPPET.md"
  local agents_snippet="$SNIPPETS_TEMPLATE_DIR/AGENTS_SNIPPET.md"

  # AGENTS.md (Codex) and GEMINI.md (Gemini) use the same provider-agnostic snippet.
  if { [ "$target_basename" = "AGENTS.md" ] || [ "$target_basename" = "GEMINI.md" ]; } && [ -f "$agents_snippet" ]; then
    printf '%s\n' "$agents_snippet"
    return 0
  fi

  if [ -f "$default_snippet" ]; then
    printf '%s\n' "$default_snippet"
    return 0
  fi

  err "Missing snippet template: $default_snippet"
  return 1
}

  cmd_patch_agent_files() {
    local target
  for target in "$PROJECT_ROOT/CLAUDE.md" "$PROJECT_ROOT/AGENTS.md" "$PROJECT_ROOT/GEMINI.md"; do
    local base
    base="$(basename "$target")"

    local snippet
    snippet="$(select_snippet_for_target "$base")"

    upsert_marked_block "$target" "$snippet"
  done

  log "[patch-agent-files] Done"
}

cmd_package_check() {
  if run_package_check; then
    return 0
  fi

  err "[package-check] FAILED - runtime artifacts detected"
  return 1
}

